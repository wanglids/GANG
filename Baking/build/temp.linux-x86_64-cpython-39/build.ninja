ninja_required_version = 1.3
cxx = c++
nvcc = /usr/local/cuda/bin/nvcc

cflags = -pthread -B /opt/conda/envs/relightgs/compiler_compat -Wl,--sysroot=/ -Wno-unused-result -Wsign-compare -DNDEBUG -fwrapv -O2 -Wall -fPIC -O2 -isystem /opt/conda/envs/relightgs/include -fPIC -O2 -isystem /opt/conda/envs/relightgs/include -fPIC -I/opt/conda/envs/relightgs/lib/python3.9/site-packages/torch/include -I/opt/conda/envs/relightgs/lib/python3.9/site-packages/torch/include/torch/csrc/api/include -I/opt/conda/envs/relightgs/lib/python3.9/site-packages/torch/include/TH -I/opt/conda/envs/relightgs/lib/python3.9/site-packages/torch/include/THC -I/usr/local/cuda/include -I/opt/conda/envs/relightgs/include/python3.9 -c
post_cflags = -DTORCH_API_INCLUDE_EXTENSION_H '-DPYBIND11_COMPILER_TYPE="_gcc"' '-DPYBIND11_STDLIB="_libstdcpp"' '-DPYBIND11_BUILD_ABI="_cxxabi1011"' -DTORCH_EXTENSION_NAME=_C -D_GLIBCXX_USE_CXX11_ABI=0 -std=c++14
cuda_cflags = -I/opt/conda/envs/relightgs/lib/python3.9/site-packages/torch/include -I/opt/conda/envs/relightgs/lib/python3.9/site-packages/torch/include/torch/csrc/api/include -I/opt/conda/envs/relightgs/lib/python3.9/site-packages/torch/include/TH -I/opt/conda/envs/relightgs/lib/python3.9/site-packages/torch/include/THC -I/usr/local/cuda/include -I/opt/conda/envs/relightgs/include/python3.9 -c
cuda_post_cflags = -D__CUDA_NO_HALF_OPERATORS__ -D__CUDA_NO_HALF_CONVERSIONS__ -D__CUDA_NO_BFLOAT16_CONVERSIONS__ -D__CUDA_NO_HALF2_OPERATORS__ --expt-relaxed-constexpr --compiler-options ''"'"'-fPIC'"'"'' -I -DTORCH_API_INCLUDE_EXTENSION_H '-DPYBIND11_COMPILER_TYPE="_gcc"' '-DPYBIND11_STDLIB="_libstdcpp"' '-DPYBIND11_BUILD_ABI="_cxxabi1011"' -DTORCH_EXTENSION_NAME=_C -D_GLIBCXX_USE_CXX11_ABI=0 -gencode=arch=compute_80,code=compute_80 -gencode=arch=compute_80,code=sm_80 -std=c++14
cuda_dlink_post_cflags = 
ldflags = 

rule compile
  command = $cxx -MMD -MF $out.d $cflags -c $in -o $out $post_cflags
  depfile = $out.d
  deps = gcc

rule cuda_compile
  depfile = $out.d
  deps = gcc
  command = $nvcc  $cuda_cflags -c $in -o $out $cuda_post_cflags





build /a800data1/lideqi/Ours_test/Octree_Ours_1122/Baking/build/temp.linux-x86_64-cpython-39/src/bindings.o: compile /a800data1/lideqi/Ours_test/Octree_Ours_1122/Baking/src/bindings.cpp
build /a800data1/lideqi/Ours_test/Octree_Ours_1122/Baking/build/temp.linux-x86_64-cpython-39/src/irradiance_kernel.o: cuda_compile /a800data1/lideqi/Ours_test/Octree_Ours_1122/Baking/src/irradiance_kernel.cu
build /a800data1/lideqi/Ours_test/Octree_Ours_1122/Baking/build/temp.linux-x86_64-cpython-39/src/occlusion_kernel.o: cuda_compile /a800data1/lideqi/Ours_test/Octree_Ours_1122/Baking/src/occlusion_kernel.cu







