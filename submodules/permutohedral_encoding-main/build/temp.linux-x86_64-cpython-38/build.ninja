ninja_required_version = 1.3
cxx = /usr/bin/g++-11
nvcc = /home/dqli/cuda-11.8/bin/nvcc

cflags = -Wsign-compare -DNDEBUG -g -fwrapv -O3 -Wall -Wstrict-prototypes -fPIC -I/home/dqli/program/code_ours/GANG/submodules/permutohedral_encoding-main/include -I/home/dqli/program/code_ours/GANG/submodules/permutohedral_encoding-main/kernels -I/home/dqli/program/code_ours/GANG/submodules/permutohedral_encoding-main/deps -I/home/dqli/anaconda3/envs/GANG/lib/python3.8/site-packages/torch/include -I/home/dqli/anaconda3/envs/GANG/lib/python3.8/site-packages/torch/include/torch/csrc/api/include -I/home/dqli/anaconda3/envs/GANG/lib/python3.8/site-packages/torch/include/TH -I/home/dqli/anaconda3/envs/GANG/lib/python3.8/site-packages/torch/include/THC -I/home/dqli/cuda-11.8/include -I/home/dqli/anaconda3/envs/GANG/include/python3.8 -c
post_cflags = -std=c++14 -DPENC_MIN_GPU_ARCH=86 -DTORCH_API_INCLUDE_EXTENSION_H '-DPYBIND11_COMPILER_TYPE="_gcc"' '-DPYBIND11_STDLIB="_libstdcpp"' '-DPYBIND11_BUILD_ABI="_cxxabi1011"' -DTORCH_EXTENSION_NAME=_86_C -D_GLIBCXX_USE_CXX11_ABI=0
cuda_cflags = -I/home/dqli/program/code_ours/GANG/submodules/permutohedral_encoding-main/include -I/home/dqli/program/code_ours/GANG/submodules/permutohedral_encoding-main/kernels -I/home/dqli/program/code_ours/GANG/submodules/permutohedral_encoding-main/deps -I/home/dqli/anaconda3/envs/GANG/lib/python3.8/site-packages/torch/include -I/home/dqli/anaconda3/envs/GANG/lib/python3.8/site-packages/torch/include/torch/csrc/api/include -I/home/dqli/anaconda3/envs/GANG/lib/python3.8/site-packages/torch/include/TH -I/home/dqli/anaconda3/envs/GANG/lib/python3.8/site-packages/torch/include/THC -I/home/dqli/cuda-11.8/include -I/home/dqli/anaconda3/envs/GANG/include/python3.8 -c
cuda_post_cflags = -D__CUDA_NO_HALF_OPERATORS__ -D__CUDA_NO_HALF_CONVERSIONS__ -D__CUDA_NO_BFLOAT16_CONVERSIONS__ -D__CUDA_NO_HALF2_OPERATORS__ --expt-relaxed-constexpr --compiler-options ''"'"'-fPIC'"'"'' -std=c++14 --generate-line-info --extended-lambda --expt-relaxed-constexpr -U__CUDA_NO_HALF_OPERATORS__ -U__CUDA_NO_HALF_CONVERSIONS__ -U__CUDA_NO_HALF2_OPERATORS__ -Xcompiler=-Wno-float-conversion -Xcompiler=-fno-strict-aliasing -gencode=arch=compute_86,code=compute_86 -gencode=arch=compute_86,code=sm_86 -DPENC_MIN_GPU_ARCH=86 -DTORCH_API_INCLUDE_EXTENSION_H '-DPYBIND11_COMPILER_TYPE="_gcc"' '-DPYBIND11_STDLIB="_libstdcpp"' '-DPYBIND11_BUILD_ABI="_cxxabi1011"' -DTORCH_EXTENSION_NAME=_86_C -D_GLIBCXX_USE_CXX11_ABI=0 -ccbin /usr/bin/gcc-11
cuda_dlink_post_cflags = 
ldflags = 

rule compile
  command = $cxx -MMD -MF $out.d $cflags -c $in -o $out $post_cflags
  depfile = $out.d
  deps = gcc

rule cuda_compile
  depfile = $out.d
  deps = gcc
  command = $nvcc  $cuda_cflags -c $in -o $out $cuda_post_cflags





build /home/dqli/program/code_ours/GANG/submodules/permutohedral_encoding-main/build/temp.linux-x86_64-cpython-38/./src/Encoding.o: cuda_compile /home/dqli/program/code_ours/GANG/submodules/permutohedral_encoding-main/src/Encoding.cu
build /home/dqli/program/code_ours/GANG/submodules/permutohedral_encoding-main/build/temp.linux-x86_64-cpython-38/./src/PyBridge.o: compile /home/dqli/program/code_ours/GANG/submodules/permutohedral_encoding-main/src/PyBridge.cxx







